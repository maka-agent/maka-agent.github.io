---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
  priority?: boolean;
  class?: string;
}

const { src, alt, caption, priority = false, class: className = "" } = Astro.props;
---

<figure class:list={["product-frame", className]}>
  <div class="product-frame__chrome" aria-hidden="true">
    <span></span><span></span><span></span>
    <span class="product-frame__path">MAKA / LOCAL WORKSPACE</span>
  </div>
  <Image
    src={src}
    alt={alt}
    widths={[640, 960, 1280, 1920]}
    sizes="(max-width: 48rem) 94vw, (max-width: 75rem) 82vw, 70vw"
    format="webp"
    quality={84}
    loading={priority ? "eager" : "lazy"}
    fetchpriority={priority ? "high" : "auto"}
    decoding="async"
  />
  <figcaption>{caption}</figcaption>
</figure>
