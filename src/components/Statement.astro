---
import Ticks from "./Ticks.astro";
---

<section class="band band--paper statement" data-theme="paper" data-section="02 THESIS">
  <Ticks />
  <p class="statement-text" id="statement">
    <span>PROGRESS</span>
    <span>HAS A</span>
    <span>MEMORY</span>
  </p>
</section>

<style>
  .statement {
    min-height: 88svh;
    display: grid;
    place-items: center;
  }

  .statement-text {
    --fill: 0%;
    text-align: center;
    font-size: clamp(3.4rem, 11vw, 12rem);
    font-weight: 800;
    line-height: 0.93;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    background-image: linear-gradient(
      90deg,
      var(--ink) 0 var(--fill),
      rgba(19, 19, 22, 0.1) var(--fill)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .statement-text span {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .statement-text {
      --fill: 100%;
    }
  }
</style>
