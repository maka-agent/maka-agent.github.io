---
import { Image } from "astro:assets";
import heroGlass from "../assets/maka-glass-hero-v2.png";
---

<div class="execution-field" aria-hidden="true">
  <div class="execution-field__hero" data-hero-glass>
    <Image
      src={heroGlass}
      alt=""
      widths={[768, 1200, 1672]}
      sizes="100vw"
      format="webp"
      quality={95}
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <canvas
    id="execution-field"
    data-engine="three.js r184"
    data-wordmark="Maka"
    data-wordmark-geometry="continuous-cursive-ribbon"
  ></canvas>
  <svg class="execution-field__fallback" viewBox="0 0 1600 1000" preserveAspectRatio="xMidYMid meet">
    <defs>
      <filter id="fallback-soft" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="18" />
      </filter>
    </defs>
    <g class="fallback-light" filter="url(#fallback-soft)">
      <ellipse cx="850" cy="470" rx="410" ry="260" />
    </g>
    <text class="fallback-wordmark" x="805" y="560" text-anchor="middle" transform="rotate(-1 805 490)">Maka</text>
    <g class="fallback-satellites">
      <rect x="250" y="245" width="82" height="82" rx="23" transform="rotate(-18 291 286)" />
      <circle cx="1245" cy="640" r="46" />
      <path d="M1192 256h78l20 106h-118z" />
    </g>
  </svg>
</div>

<script src="../scripts/execution-field.ts"></script>
