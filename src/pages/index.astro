---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ExecutionField from "../components/ExecutionField.astro";
import artifactCurrent from "../assets/maka-artifact-pane.png";
import permissionCurrent from "../assets/maka-permission-fresh.png";
import questionCurrent from "../assets/maka-question-fresh.png";
import firstRunCurrent from "../assets/maka-first-run.png";
import errorsCurrent from "../assets/maka-artifact-errors.png";

const githubUrl = "https://github.com/maka-agent/maka-agent";
const architectureUrl = `${githubUrl}/blob/main/ARCHITECTURE.md`;
---

<BaseLayout
  title="Maka — Your work. Your agent."
  description="A local-first Agent workspace where tools, permissions, artifacts, and durable progress stay visible."
>
  <div class="stage" data-view="overview" id="top">
    <div class="boot-loader" aria-hidden="true">
      <span><i></i> MAKA</span>
      <b></b>
    </div>
    <ExecutionField />
    <div class="light-field" aria-hidden="true"><i></i><i></i><i></i></div>

    <div class="measurement-grid" aria-hidden="true">
      <i class="rule rule--v rule--v1"></i>
      <i class="rule rule--v rule--v2"></i>
      <i class="rule rule--v rule--v3"></i>
      <i class="rule rule--h rule--h1"></i>
      <i class="cross cross--a"></i>
      <i class="cross cross--b"></i>
      <i class="cross cross--c"></i>
    </div>

    <header class="stage-header" aria-label="Primary navigation">
      <a class="brand" href="#overview" data-view-target="overview" aria-label="Maka home">
        <svg viewBox="0 0 34 34" aria-hidden="true">
          <path d="M10 5H5v24h5M24 5h5v24h-5" />
          <circle cx="17" cy="17" r="3" />
        </svg>
        <span>MAKA</span>
      </a>

      <nav class="view-nav" aria-label="Explore Maka">
        <a href="#overview" data-view-target="overview" aria-current="page"><span>Overview</span><small>[1]</small></a>
        <a href="#product" data-view-target="product"><span>Product</span><small>[2]</small></a>
        <a href="#runtime" data-view-target="runtime"><span>Runtime</span><small>[3]</small></a>
        <a href="#surfaces" data-view-target="surfaces"><span>Surfaces</span><small>[4]</small></a>
      </nav>

      <div class="shell-commands">
        <button class="theme-command" type="button" data-theme-command aria-pressed="false" aria-label="Toggle night theme">
          <span>Theme</span><small>[T]</small>
        </button>
        <a class="source-link" href={githubUrl} target="_blank" rel="noreferrer" aria-label="View Maka source on GitHub">
          <span>View source</span>
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 12 12 4M6 4h6v6" /></svg>
        </a>
      </div>
    </header>

    <main id="main-content" class="stage-main">
      <section class="view view--overview is-active" id="overview" data-view-panel="overview" aria-labelledby="overview-title" aria-hidden="false">
        <div class="overview-note overview-note--identity">
          <strong>LOCAL-FIRST<br />AGENT WORKSPACE</strong>
          <p>Work on your machine.<br />Keep every decision visible.</p>
        </div>

        <div class="overview-note overview-note--model">
          <span class="signal-dot"></span>
          <p>Task → Tool Call → Artifact</p>
          <p>One continuous execution record.</p>
        </div>

        <div class="overview-note overview-note--trust">
          <p>Your connections.<br />Your permission boundary.</p>
          <a href={architectureUrl} target="_blank" rel="noreferrer">Read architecture ↗</a>
        </div>

        <div class="hero-copy">
          <p class="hero-copy__signal"><span></span> EXECUTION, MADE TANGIBLE</p>
          <h1 id="overview-title"><span>YOUR WORK.</span><span>YOUR AGENT.</span></h1>
          <div class="hero-copy__footer">
            <p>Maka turns agent conversations into<br />inspectable, recoverable local work.</p>
            <a class="primary-action" href="#product" data-view-target="product">
              Enter workspace
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" /></svg>
            </a>
          </div>
        </div>

        <ol class="object-index" aria-label="Maka execution objects">
          <li><span>01</span><b>Task</b><small>intent</small></li>
          <li><span>02</span><b>Tool</b><small>action</small></li>
          <li><span>03</span><b>Artifact</b><small>proof</small></li>
        </ol>
      </section>

      <section class="view view--product" id="product" data-view-panel="product" aria-labelledby="product-title" aria-hidden="true" inert>
        <div class="product-copy">
          <p class="section-signal"><span></span>REAL MAKA / CURRENT SOURCE</p>
          <h2 id="product-title">Real work.<br />Visible proof.</h2>
          <p>Conversation, Tool Calls, permissions, and generated files stay attached to one task. Inspect what ran and what remains.</p>
          <div class="product-facts" aria-label="Product facts">
            <p><b>ATTACHED</b><span>Files stay with the turn that made them.</span></p>
            <p><b>EXPLICIT</b><span>Tool Calls cross a visible boundary.</span></p>
            <p><b>DURABLE</b><span>Interrupted work can be resumed.</span></p>
          </div>
        </div>

        <div class="product-gallery" aria-label="Current Maka interface previews">
          <figure class="product-shot product-shot--main">
            <div class="product-shot__bar">
              <span>maka-agent / artifact task</span>
              <i>LOCAL <span class="product-shot__mode">· INSPECT</span></i>
            </div>
            <div class="product-shot__visual" data-product-inspector data-evidence="artifact" tabindex="0" aria-label="Inspect the current Maka artifact task screenshot">
              <Image
                src={artifactCurrent}
                alt="Current Maka task showing a Tool Call beside three generated files and their inspectable artifact pane."
                widths={[960, 1280, 1600, 1920]}
                sizes="(max-width: 760px) 132vw, 65vw"
                format="webp"
                quality={92}
                loading="eager"
                fetchpriority="high"
                data-evidence-panel="artifact"
              />
              <Image
                src={firstRunCurrent}
                alt="Maka first-run provider setup: a three-step flow for choosing an AI provider, completing authentication, and testing the default connection."
                widths={[960, 1280, 1600]}
                sizes="(max-width: 760px) 132vw, 65vw"
                format="webp"
                quality={88}
                loading="eager"
                data-evidence-panel="first-run"
              />
              <Image
                src={errorsCurrent}
                alt="Maka artifact task showing an interrupted Tool Call and a deleted generated file surfaced as an explicit unreadable-file error."
                widths={[960, 1280, 1600]}
                sizes="(max-width: 760px) 132vw, 65vw"
                format="webp"
                quality={88}
                loading="eager"
                data-evidence-panel="errors"
              />
              <canvas id="product-hover-field" aria-hidden="true" data-hover-state="loading"></canvas>
            </div>
            <figcaption>
              <span>REAL PRODUCT</span>
              <span class="evidence-index" role="group" aria-label="Switch product evidence">
                <button type="button" data-evidence-command="artifact" aria-pressed="true">01 Artifact</button>
                <button type="button" data-evidence-command="first-run" aria-pressed="false">02 First run</button>
                <button type="button" data-evidence-command="errors" aria-pressed="false">03 Errors</button>
              </span>
              <b data-evidence-caption>Tool Call → Artifact</b>
            </figcaption>
          </figure>

          <figure class="product-proof product-proof--streaming">
            <Image
              src={permissionCurrent}
              alt="Current Maka file-edit permission prompt showing the exact proposed change and explicit deny or allow controls."
              widths={[720, 960, 1280]}
              sizes="(max-width: 760px) 72vw, 38vw"
              format="webp"
              quality={86}
              loading="eager"
            />
            <figcaption><span>PERMISSION</span><b>02</b></figcaption>
          </figure>

          <figure class="product-proof product-proof--empty">
            <Image
              src={questionCurrent}
              alt="Current Maka clarification surface with explicit release choices kept inside the task conversation."
              widths={[720, 960, 1280]}
              sizes="(max-width: 760px) 72vw, 38vw"
              format="webp"
              quality={86}
              loading="eager"
            />
            <figcaption><span>CLARIFICATION</span><b>03</b></figcaption>
          </figure>
        </div>
      </section>

      <section class="view view--runtime" id="runtime" data-view-panel="runtime" aria-labelledby="runtime-title" aria-hidden="true" inert>
        <div class="runtime-copy">
          <p class="section-signal section-signal--light"><span></span>APPEND-ONLY EXECUTION</p>
          <h2 id="runtime-title">Progress has<br />a memory.</h2>
          <p>Messages, Tool Calls, Tool Results, permission decisions, and termination facts enter one Event Log. Context, UI, and recovery are projections over the same recorded execution.</p>
          <a href={architectureUrl} target="_blank" rel="noreferrer">Inspect the architecture ↗</a>
        </div>

        <div class="runtime-stage" data-runtime-path aria-label="Maka runtime event flow">
          <div class="runtime-rail" aria-hidden="true"><i></i></div>
          <ol class="runtime-flow">
            <li class="runtime-step runtime-step--request" data-runtime-phase="request">
              <span>01 / INPUT</span><b>Request</b><small>A turn begins</small>
            </li>
            <li class="runtime-step runtime-step--run" data-runtime-phase="agent-run">
              <span>02 / EXECUTE</span><b>AgentRun</b><small>Model and tools advance</small>
            </li>
            <li class="runtime-step runtime-step--hub" data-runtime-phase="event-log" data-runtime-hub>
              <span>03 / APPEND ONLY</span>
              <strong><i>Event</i><i>Log</i></strong>
              <small>Messages · Tool Calls · Results · Permissions · Termination</small>
            </li>
            <li class="runtime-step runtime-step--projection" data-runtime-phase="projection">
              <span>04 / PROJECT</span><b>Projection</b><small>Context and interface</small>
            </li>
            <li class="runtime-step runtime-step--recovery" data-runtime-phase="recovery">
              <span>05 / RESUME</span><b>Recovery</b><small>Interrupted work survives</small>
            </li>
          </ol>

          <div class="runtime-ledger" data-runtime-statement>
            <span>ONE RECORDED EXECUTION</span>
            <p>Every surface is rebuilt from what happened—not from hidden state.</p>
          </div>
        </div>
      </section>

      <section class="view view--surfaces" id="surfaces" data-view-panel="surfaces" aria-labelledby="surfaces-title" aria-hidden="true" inert>
        <div class="surfaces-lede">
          <p class="section-signal"><span></span>ONE RUNTIME / FOUR SURFACES</p>
          <h2 id="surfaces-title" class="surfaces-statement" aria-label="Same runtime. Every surface.">
            <span class="decode-line" data-decode="SAME RUNTIME." aria-hidden="true">SAME RUNTIME.</span>
            <span class="decode-line" data-decode="EVERY SURFACE." aria-hidden="true">EVERY SURFACE.</span>
          </h2>
          <p class="surfaces-sub">
            Desktop, TUI, CLI, and Headless share one workspace,<br />
            one set of model connections, and one execution record.
          </p>
        </div>

        <ol class="surface-index" aria-label="Maka surfaces">
          <li>
            <span>01</span>
            <b>Desktop</b>
            <small>Daily interaction, file and Artifact workflows, permission setup.</small>
          </li>
          <li>
            <span>02</span>
            <b>TUI</b>
            <small>The same workspace, driven from the current project directory.</small>
          </li>
          <li>
            <span>03</span>
            <b>CLI</b>
            <small>One non-interactive turn, scripted with <i>maka run</i>.</small>
          </li>
          <li>
            <span>04</span>
            <b>Headless</b>
            <small>Durable TaskRuns that can be interrupted, inspected, and resumed.</small>
          </li>
        </ol>

        <div class="surfaces-close">
          <p class="surfaces-trust">Source-first today. Read it before you run it.</p>
          <div class="surfaces-actions">
            <a class="primary-action" href={githubUrl} target="_blank" rel="noreferrer">
              View source
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 12 12 4M6 4h6v6" /></svg>
            </a>
            <a class="surfaces-secondary" href={architectureUrl} target="_blank" rel="noreferrer">Read architecture ↗</a>
          </div>
          <p class="surfaces-colophon">OPEN SOURCE · LOCAL-FIRST · MAKA-AGENT.COM</p>
        </div>
      </section>
    </main>

    <footer class="stage-footer">
      <p class="stage-caption">LOCAL EXECUTION / OPEN SOURCE</p>
      <p class="stage-status"><span class="stage-status__pulse"></span><b id="telemetry-view">OVERVIEW</b><em>01 / 04</em></p>
      <p class="pointer-readout" aria-label="Pointer coordinates"><b id="pointer-x">0000</b><span>X</span><b id="pointer-y">0000</b><span>Y</span></p>
      <p class="local-time" aria-label="Local time"><span>LOCAL</span> <b id="local-time">--:--:--</b></p>
      <a href={githubUrl} target="_blank" rel="noreferrer">github.com/maka-agent/maka-agent</a>
    </footer>

  </div>

  <script src="../scripts/product-hover-field.ts"></script>
  <script>
    const stage = document.querySelector<HTMLElement>(".stage");
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-view-target]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-view-panel]"));
    const statusLabel = document.querySelector<HTMLElement>("#telemetry-view");
    const statusIndex = document.querySelector<HTMLElement>(".stage-status em");
    const pointerX = document.querySelector<HTMLElement>("#pointer-x");
    const pointerY = document.querySelector<HTMLElement>("#pointer-y");
    const timeReadout = document.querySelector<HTMLElement>("#local-time");
    const lightField = document.querySelector<HTMLElement>(".light-field");
    const views = ["overview", "product", "runtime", "surfaces"] as const;
    const transitionDurations = { overview: 900, product: 1450, runtime: 1900, surfaces: 1300 } as const;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let transitionToken = 0;

    const setView = (requested: string, updateHash = true) => {
      const view = views.includes(requested as (typeof views)[number]) ? requested : "overview";
      if (!stage || stage.dataset.view === view) return;
      const outgoing = stage.dataset.view ?? "overview";
      const token = ++transitionToken;
      if (!reduceMotion.matches) {
        stage.dataset.entering = view;
        stage.dataset.transitioning = `${outgoing}-to-${view}`;
        stage.dataset.transitionDuration = String(transitionDurations[view as keyof typeof transitionDurations]);
      } else {
        delete stage.dataset.entering;
        delete stage.dataset.transitioning;
        delete stage.dataset.transitionDuration;
      }
      stage.dataset.view = view;
      panels.forEach((panel) => {
        const active = panel.dataset.viewPanel === view;
        panel.classList.toggle("is-active", active);
        panel.toggleAttribute("inert", !active);
        panel.setAttribute("aria-hidden", String(!active));
      });
      links.forEach((link) => {
        if (link.closest(".brand")) return;
        if (link.dataset.viewTarget === view) link.setAttribute("aria-current", "page");
        else link.removeAttribute("aria-current");
      });
      const index = views.indexOf(view as (typeof views)[number]);
      if (statusLabel) {
        statusLabel.textContent = view.toUpperCase();
        if (!reduceMotion.matches) {
          statusLabel.animate(
            [
              { opacity: 0, transform: "translate3d(0, 0.35rem, 0)" },
              { opacity: 1, transform: "translate3d(0, 0, 0)" },
            ],
            { duration: 420, easing: "cubic-bezier(0.16, 1, 0.3, 1)" },
          );
        }
      }
      if (statusIndex) statusIndex.textContent = `0${index + 1} / 04`;
      if (updateHash) history.replaceState(null, "", `#${view}`);
      window.dispatchEvent(new CustomEvent("maka:viewchange", { detail: { view, index } }));

      if (!reduceMotion.matches) {
        const duration = transitionDurations[view as keyof typeof transitionDurations];
        const clearEntering = () => {
          if (token !== transitionToken || !stage) return;
          delete stage.dataset.entering;
        };
        const clearTransitioning = () => {
          if (token !== transitionToken || !stage) return;
          delete stage.dataset.transitioning;
          delete stage.dataset.transitionDuration;
        };
        // rAF path plays the entrance animation on a visible page: a forced
        // reflow commits the entering styles before the flag is removed.
        requestAnimationFrame(() => {
          if (token !== transitionToken || !stage) return;
          stage.querySelector<HTMLElement>(`[data-view-panel="${view}"]`)?.getBoundingClientRect();
          requestAnimationFrame(clearEntering);
        });
        // Timer fallback: rAF is paused while the page is hidden, so without
        // this the entering flag — which gates semantic content opacity —
        // could stall at 0. Timers still fire when hidden, so content always
        // reaches its settled, visible state.
        window.setTimeout(clearEntering, 120);
        window.setTimeout(clearTransitioning, duration);
      }
    };

    links.forEach((link) => link.addEventListener("click", (event) => {
      event.preventDefault();
      setView(link.dataset.viewTarget ?? "overview");
    }));

    const evidenceCaptions: Record<string, string> = {
      artifact: "Tool Call → Artifact",
      "first-run": "First run → Providers",
      errors: "Failure → Visible",
    };
    const evidenceHost = document.querySelector<HTMLElement>("[data-product-inspector]");
    const evidenceCaption = document.querySelector<HTMLElement>("[data-evidence-caption]");
    const evidenceCommands = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-evidence-command]"));
    evidenceCommands.forEach((command) => command.addEventListener("click", () => {
      const key = command.dataset.evidenceCommand ?? "artifact";
      if (evidenceHost) evidenceHost.dataset.evidence = key;
      if (evidenceCaption) evidenceCaption.textContent = evidenceCaptions[key] ?? evidenceCaptions.artifact;
      evidenceCommands.forEach((other) => other.setAttribute("aria-pressed", String(other === command)));
    }));

    const themeCommand = document.querySelector<HTMLButtonElement>("[data-theme-command]");
    const syncThemeCommand = () => {
      const night = document.documentElement.dataset.theme === "night";
      themeCommand?.setAttribute("aria-pressed", String(night));
      window.dispatchEvent(new CustomEvent("maka:themechange", { detail: { night } }));
    };
    const toggleTheme = () => {
      const night = document.documentElement.dataset.theme === "night";
      if (night) delete document.documentElement.dataset.theme;
      else document.documentElement.dataset.theme = "night";
      try { localStorage.setItem("maka-theme", night ? "day" : "night"); } catch {}
      syncThemeCommand();
    };
    themeCommand?.addEventListener("click", toggleTheme);
    syncThemeCommand();

    const DECODE_GLYPHS = "·:=+*/<>[]{}|\\01";
    const decodeLines = Array.from(document.querySelectorAll<HTMLElement>("[data-decode]"));
    let decodeToken = 0;

    const settleDecode = () => {
      decodeToken += 1;
      decodeLines.forEach((line) => { line.textContent = line.dataset.decode ?? ""; });
    };

    const runDecode = () => {
      if (reduceMotion.matches) { settleDecode(); return; }
      const token = ++decodeToken;
      const started = performance.now();
      const LINE_DELAY = 260;
      const CHAR_STEP = 46;
      const RESOLVE = 320;
      const frame = (now: number) => {
        if (token !== decodeToken) return;
        let unfinished = false;
        decodeLines.forEach((line, lineIndex) => {
          const target = line.dataset.decode ?? "";
          const local = now - started - lineIndex * LINE_DELAY;
          let output = "";
          for (let i = 0; i < target.length; i += 1) {
            const charTime = local - i * CHAR_STEP;
            if (target[i] === " ") { output += " "; continue; }
            if (charTime < 0) { output += " "; unfinished = true; continue; }
            if (charTime < RESOLVE) {
              output += DECODE_GLYPHS[(i * 7 + Math.floor(charTime / 52)) % DECODE_GLYPHS.length];
              unfinished = true;
              continue;
            }
            output += target[i];
          }
          line.textContent = output;
        });
        if (unfinished) requestAnimationFrame(frame);
      };
      requestAnimationFrame(frame);
    };

    window.addEventListener("maka:viewchange", (event) => {
      const detail = (event as CustomEvent<{ view: string }>).detail;
      if (detail.view === "surfaces") runDecode();
      else settleDecode();
    });

    window.addEventListener("keydown", (event) => {
      if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
      if (["1", "2", "3", "4"].includes(event.key)) {
        setView(views[Number(event.key) - 1]);
        return;
      }
      if (event.key === "t" || event.key === "T") {
        toggleTheme();
        return;
      }
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
      const current = views.indexOf((stage?.dataset.view ?? "overview") as (typeof views)[number]);
      const next = event.key === "ArrowRight" ? Math.min(views.length - 1, current + 1) : Math.max(0, current - 1);
      setView(views[next]);
    });

    const formatCoordinate = (value: number) => String(Math.max(0, Math.round(value))).padStart(4, "0");
    const renderPointerCoordinates = (clientX: number, clientY: number) => {
      if (pointerX) pointerX.textContent = formatCoordinate(clientX);
      if (pointerY) pointerY.textContent = formatCoordinate(clientY);
    };

    renderPointerCoordinates(innerWidth / 2, innerHeight / 2);

    window.addEventListener("pointermove", (event) => {
      const normalizedX = event.clientX / innerWidth - 0.5;
      const normalizedY = event.clientY / innerHeight - 0.5;
      renderPointerCoordinates(event.clientX, event.clientY);
      if (stage && event.pointerType !== "touch") stage.dataset.pointer = "engaged";
      if (lightField) lightField.style.transform = `translate3d(${normalizedX * -18}px, ${normalizedY * -12}px, 0)`;
      window.dispatchEvent(new CustomEvent("maka:pointer", {
        detail: {
          x: event.clientX,
          y: event.clientY,
          normalizedX: normalizedX * 2,
          normalizedY: normalizedY * -2,
          pointerType: event.pointerType,
        },
      }));
    }, { passive: true });

    const updateTime = () => {
      if (timeReadout) timeReadout.textContent = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false,
      }).format(new Date());
    };
    updateTime();
    window.setInterval(updateTime, 1000);

    const initialView = location.hash.slice(1);
    if (initialView && initialView !== "overview") setView(initialView, false);
    if (initialView) requestAnimationFrame(() => window.scrollTo(0, 0));
  </script>
</BaseLayout>
