---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ExecutionField from "../components/ExecutionField.astro";
import shellCurrent from "../assets/maka-shell-current.png";
import shellStreaming from "../assets/maka-shell-streaming.png";
import shellEmpty from "../assets/maka-shell-empty.png";

const githubUrl = "https://github.com/maka-agent/maka-agent";
const architectureUrl = `${githubUrl}/blob/main/ARCHITECTURE.md`;
---

<BaseLayout
  title="Maka — Your work. Your agent."
  description="A local-first Agent workspace where tools, permissions, artifacts, and durable progress stay visible."
>
  <div class="stage" data-view="overview" id="top">
    <ExecutionField />

    <div class="measurement-grid" aria-hidden="true">
      <i class="rule rule--v rule--v1"></i>
      <i class="rule rule--v rule--v2"></i>
      <i class="rule rule--v rule--v3"></i>
      <i class="rule rule--v rule--v4"></i>
      <i class="rule rule--h rule--h1"></i>
      <i class="rule rule--h rule--h2"></i>
      <i class="cross cross--a"></i>
      <i class="cross cross--b"></i>
      <i class="cross cross--c"></i>
      <i class="cross cross--d"></i>
    </div>

    <header class="stage-header" aria-label="Primary navigation">
      <a class="brand" href="#overview" data-view-target="overview" aria-label="Maka home">
        <svg viewBox="0 0 34 34" aria-hidden="true">
          <path d="M10 5H5v24h5M24 5h5v24h-5" />
          <circle cx="17" cy="17" r="3" />
        </svg>
        <span>MAKA</span>
      </a>

      <nav class="view-nav" aria-label="Explore Maka">
        <a href="#overview" data-view-target="overview" aria-current="page">Overview</a>
        <a href="#product" data-view-target="product">Product</a>
        <a href="#runtime" data-view-target="runtime">Runtime</a>
      </nav>

      <a class="source-link" href={githubUrl} target="_blank" rel="noreferrer" aria-label="View Maka source on GitHub">
        <span>View source</span>
        <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 12 12 4M6 4h6v6" /></svg>
      </a>
    </header>

    <main id="main-content" class="stage-main">
      <section class="view view--overview is-active" id="overview" data-view-panel="overview" aria-labelledby="overview-title" aria-hidden="false">
        <div class="overview-note overview-note--identity">
          <strong>A local-first<br />Agent workspace.</strong>
          <p>Built for real work,<br />not disposable chat.</p>
        </div>

        <div class="overview-note overview-note--model">
          <span class="signal-dot"></span>
          <p>Task → Tool Call → Artifact</p>
          <p>Every step stays inspectable.</p>
        </div>

        <div class="overview-note overview-note--trust">
          <p>Your machine. Your connections.<br />Your permission boundary.</p>
          <a href={architectureUrl} target="_blank" rel="noreferrer">Read architecture ↗</a>
        </div>

        <div class="hero-copy">
          <p class="hero-copy__signal"><span>●</span> EXECUTION READY</p>
          <h1 id="overview-title"><span>YOUR WORK.</span><span>YOUR AGENT.</span></h1>
          <div class="hero-copy__footer">
            <p>Maka turns agent conversations into<br />visible, recoverable execution.</p>
            <a class="primary-action" href="#product" data-view-target="product">
              See Maka work
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" /></svg>
            </a>
          </div>
        </div>

        <ol class="object-index" aria-label="Maka execution objects">
          <li><span>01</span><b>Task</b></li>
          <li><span>02</span><b>Tool</b></li>
          <li><span>03</span><b>Artifact</b></li>
          <li><span>04</span><b>Recovery</b></li>
        </ol>
      </section>

      <section class="view view--product" id="product" data-view-panel="product" aria-labelledby="product-title" aria-hidden="true" inert>
        <div class="product-copy">
          <p class="section-signal"><span></span>REAL PRODUCT / CURRENT SOURCE</p>
          <h2 id="product-title">The work<br />stays visible.</h2>
          <p>Conversation, Tool Calls, permissions, and output live on the same working plane—so you can understand what happened without reconstructing it from chat.</p>
          <div class="product-facts" aria-label="Product facts">
            <p><b>LOCAL</b><span>Records stay on your machine by default.</span></p>
            <p><b>VISIBLE</b><span>Execution remains attached to the turn.</span></p>
            <p><b>DURABLE</b><span>Interrupted work can be recovered.</span></p>
          </div>
        </div>

        <div class="product-gallery" aria-label="Current Maka interface previews">
          <figure class="product-shot product-shot--main">
            <div class="product-shot__bar"><span>maka-agent / task workspace</span><i></i></div>
            <Image
              src={shellCurrent}
              alt="Current Maka desktop workspace with task sidebar, real conversation, model controls, and composer."
              widths={[960, 1280, 1600]}
              sizes="(max-width: 760px) 94vw, 70vw"
              format="webp"
              quality={88}
              loading="eager"
              fetchpriority="high"
            />
            <figcaption><span>01</span>Conversation + workspace</figcaption>
          </figure>

          <figure class="product-shot product-shot--streaming">
            <Image
              src={shellStreaming}
              alt="Current Maka desktop workspace while an agent turn is streaming."
              widths={[640, 960]}
              sizes="(max-width: 760px) 44vw, 25vw"
              format="webp"
              quality={84}
              loading="eager"
            />
            <figcaption><span>02</span>Live turn</figcaption>
          </figure>

          <figure class="product-shot product-shot--empty">
            <Image
              src={shellEmpty}
              alt="Current Maka empty workspace with a direct task composer and suggested starting points."
              widths={[640, 960]}
              sizes="(max-width: 760px) 44vw, 25vw"
              format="webp"
              quality={84}
              loading="eager"
            />
            <figcaption><span>03</span>Ready state</figcaption>
          </figure>
        </div>
      </section>

      <section class="view view--runtime" id="runtime" data-view-panel="runtime" aria-labelledby="runtime-title" aria-hidden="true" inert>
        <div class="runtime-copy">
          <p class="section-signal section-signal--light"><span></span>APPEND-ONLY EXECUTION</p>
          <h2 id="runtime-title">The log is<br />the runtime.</h2>
          <p>Messages, Tool Calls, Tool Results, and termination facts enter one Event Log. Context, UI, and recovery are projections over the same recorded execution.</p>
          <a href={architectureUrl} target="_blank" rel="noreferrer">Inspect the architecture ↗</a>
        </div>

        <ol class="runtime-orbit" aria-label="Maka runtime event flow">
          <li style="--i: 0"><span>01</span><b>Request</b><small>A Turn begins</small></li>
          <li style="--i: 1"><span>02</span><b>AgentRun</b><small>Model + tools advance</small></li>
          <li style="--i: 2"><span>03</span><b>Event Log</b><small>Facts are appended</small></li>
          <li style="--i: 3"><span>04</span><b>Projection</b><small>UI + context read</small></li>
          <li style="--i: 4"><span>05</span><b>Recovery</b><small>Progress survives</small></li>
        </ol>

        <div class="runtime-code" aria-label="Architecture summary">
          <p><span>surface</span> Desktop / TUI / Headless</p>
          <p><span>engine</span> SessionManager → AgentRun</p>
          <p><span>record</span> Runtime Event Log</p>
          <p><span>result</span> Context / UI / Recovery</p>
        </div>
      </section>
    </main>

    <footer class="stage-footer">
      <p class="pointer-readout" aria-hidden="true"><span>X <b id="telemetry-x">0000</b></span><span>Y <b id="telemetry-y">0000</b></span></p>
      <p class="stage-status"><span class="stage-status__pulse"></span><b id="telemetry-view">OVERVIEW</b><em>01 / 03</em></p>
      <p class="local-time" aria-label="Local time"><span>LOCAL</span> <b id="local-time">--:--:--</b></p>
      <a href={githubUrl} target="_blank" rel="noreferrer">github.com/maka-agent/maka-agent</a>
    </footer>

    <div class="cursor-probe" aria-hidden="true"><i></i><span>RUN</span></div>
  </div>

  <script>
    const stage = document.querySelector<HTMLElement>(".stage");
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-view-target]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-view-panel]"));
    const statusLabel = document.querySelector<HTMLElement>("#telemetry-view");
    const statusIndex = document.querySelector<HTMLElement>(".stage-status em");
    const xReadout = document.querySelector<HTMLElement>("#telemetry-x");
    const yReadout = document.querySelector<HTMLElement>("#telemetry-y");
    const timeReadout = document.querySelector<HTMLElement>("#local-time");
    const probe = document.querySelector<HTMLElement>(".cursor-probe");
    const views = ["overview", "product", "runtime"] as const;

    const setView = (requested: string, updateHash = true) => {
      const view = views.includes(requested as (typeof views)[number]) ? requested : "overview";
      if (!stage || stage.dataset.view === view) return;
      stage.dataset.view = view;
      panels.forEach((panel) => {
        const active = panel.dataset.viewPanel === view;
        panel.classList.toggle("is-active", active);
        panel.toggleAttribute("inert", !active);
        panel.setAttribute("aria-hidden", String(!active));
      });
      links.forEach((link) => {
        if (link.closest(".brand")) return;
        if (link.dataset.viewTarget === view) link.setAttribute("aria-current", "page");
        else link.removeAttribute("aria-current");
      });
      const index = views.indexOf(view as (typeof views)[number]);
      if (statusLabel) statusLabel.textContent = view.toUpperCase();
      if (statusIndex) statusIndex.textContent = `0${index + 1} / 03`;
      if (updateHash) history.replaceState(null, "", `#${view}`);
      window.dispatchEvent(new CustomEvent("maka:viewchange", { detail: { view, index } }));
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        setView(link.dataset.viewTarget ?? "overview");
      });
    });

    window.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
      const current = views.indexOf((stage?.dataset.view ?? "overview") as (typeof views)[number]);
      const next = event.key === "ArrowRight" ? Math.min(views.length - 1, current + 1) : Math.max(0, current - 1);
      setView(views[next]);
    });

    let pointerX = window.innerWidth / 2;
    let pointerY = window.innerHeight / 2;
    window.addEventListener("pointermove", (event) => {
      pointerX = event.clientX;
      pointerY = event.clientY;
      if (xReadout) xReadout.textContent = String(Math.round(pointerX)).padStart(4, "0");
      if (yReadout) yReadout.textContent = String(Math.round(pointerY)).padStart(4, "0");
      if (probe) probe.style.transform = `translate3d(${pointerX}px, ${pointerY}px, 0)`;
    }, { passive: true });

    const updateTime = () => {
      if (timeReadout) timeReadout.textContent = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false,
      }).format(new Date());
    };
    updateTime();
    window.setInterval(updateTime, 1000);

    const initialView = location.hash.slice(1);
    if (initialView && initialView !== "overview") setView(initialView, false);
  </script>
</BaseLayout>
