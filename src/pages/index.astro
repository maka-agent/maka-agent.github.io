---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ExecutionField from "../components/ExecutionField.astro";
import artifactShot from "../assets/maka-artifact-pane.png";
import permissionShot from "../assets/maka-permission-fresh.png";
import questionShot from "../assets/maka-question-fresh.png";

const githubUrl = "https://github.com/maka-agent/maka-agent";
const architectureUrl = `${githubUrl}/blob/main/ARCHITECTURE.md`;
---

<BaseLayout
  title="Maka — Your work. Your agent."
  description="A local-first Agent workspace where tools, permissions, artifacts, and durable progress stay visible."
>
  <ExecutionField />

  <div class="rules" aria-hidden="true">
    <i></i><i></i><i></i><i></i><i></i>
  </div>

  <header class="shell shell--top" aria-label="Primary navigation">
    <a class="brand" href="#top" data-nav="top">MAKA</a>
    <p class="shell-role">Local-first Agent&nbsp;Workspace</p>
    <nav class="shell-nav" aria-label="Sections">
      <a href="#work" data-nav="work" data-scramble>WORK<small>[W]</small></a>
      <a href="#runtime" data-nav="runtime" data-scramble>RUNTIME<small>[R]</small></a>
      <a href={githubUrl} target="_blank" rel="noreferrer" data-scramble
        >SOURCE<small>[G]</small><span aria-hidden="true">&nbsp;↗</span></a
      >
    </nav>
  </header>

  <main id="main-content">
    <!-- 00 · HERO -->
    <section class="hero" id="top" data-theme="sky" data-section="00 INTRO">
      <div class="hero-notes">
        <p class="hero-thesis">
          Direct real work.<br />Keep every decision visible.
        </p>
        <p class="hero-mono mono">
          Directed by you.<br />Executed on your machine.
        </p>
        <p class="hero-bio mono">
          Maka is an open-source workspace for directing and supervising
          agents. Conversation, Tool&nbsp;Calls, permissions, and generated
          artifacts stay attached to one durable, recoverable task.
        </p>
      </div>

      <h1 class="hero-statement" id="hero-title">
        <span class="line"><span>YOUR&nbsp;WORK.</span></span>
        <span class="line"><span>YOUR&nbsp;AGENT.</span></span>
      </h1>

      <a class="hero-cue mono" href="#work" data-nav="work">
        <span>01&nbsp;WORK</span>
        <b aria-hidden="true">↓</b>
      </a>
    </section>

    <!-- 01 · WORK — real product proof -->
    <section class="band band--paper work" id="work" data-theme="paper" data-section="01 WORK">
      <div class="ticks" aria-hidden="true"><s></s><s></s><s></s><s></s><s></s></div>

      <header class="band-head">
        <p class="band-index mono">01</p>
        <h2 class="band-title" data-scramble>WORK</h2>
        <p class="band-note mono">Real product · current source · nothing staged</p>
      </header>

      <!-- Entry 01 -->
      <article class="entry">
        <div class="entry-row mono" aria-hidden="true">
          <span class="entry-name">ARTIFACT PANE</span>
          <span class="entry-meta">TASK / TURN / FILES</span>
          <span class="entry-tag">ATTACHED</span>
          <span class="entry-no">№01</span>
        </div>
        <div class="entry-body entry-body--wide">
          <figure class="frame">
            <Image
              src={artifactShot}
              alt="A Maka task where a Tool Call generated three files; the artifact pane shows the files and a Markdown preview beside the conversation."
              widths={[960, 1280, 1600, 1920]}
              sizes="(max-width: 760px) 94vw, 72vw"
              format="webp"
              quality={90}
              loading="eager"
              fetchpriority="high"
            />
            <figcaption class="mono">CONVERSATION → TOOL CALL → ARTIFACT</figcaption>
          </figure>
          <div class="entry-copy">
            <h3>Work becomes evidence you can inspect.</h3>
            <p>
              Generated files stay with the turn that made them. Open any
              artifact, read what ran, and verify what changed — inside the
              task, not in a downloads folder.
            </p>
          </div>
        </div>
      </article>

      <!-- Entry 02 -->
      <article class="entry">
        <div class="entry-row mono" aria-hidden="true">
          <span class="entry-name">PERMISSION BOUNDARY</span>
          <span class="entry-meta">FILE EDIT / EXACT DIFF</span>
          <span class="entry-tag">EXPLICIT</span>
          <span class="entry-no">№02</span>
        </div>
        <div class="entry-body">
          <div class="entry-copy">
            <h3>Tool&nbsp;Calls cross a visible boundary.</h3>
            <p>
              Before Maka touches a file, you see the exact proposed change and
              an explicit allow-or-deny control. Nothing runs behind your back.
            </p>
          </div>
          <figure class="frame frame--narrow">
            <Image
              src={permissionShot}
              alt="Maka's file-edit permission prompt showing the exact proposed diff and explicit deny or allow controls."
              widths={[480, 720, 1080]}
              sizes="(max-width: 760px) 94vw, 38vw"
              format="webp"
              quality={88}
            />
            <figcaption class="mono">ALLOW / DENY · SHOWN BEFORE EXECUTION</figcaption>
          </figure>
        </div>
      </article>

      <!-- Entry 03 -->
      <article class="entry">
        <div class="entry-row mono" aria-hidden="true">
          <span class="entry-name">CLARIFICATION</span>
          <span class="entry-meta">QUESTION / CHOICES</span>
          <span class="entry-tag">IN-TASK</span>
          <span class="entry-no">№03</span>
        </div>
        <div class="entry-body">
          <figure class="frame frame--narrow">
            <Image
              src={questionShot}
              alt="A Maka clarification prompt keeping explicit release choices inside the task conversation."
              widths={[480, 720, 1080]}
              sizes="(max-width: 760px) 94vw, 38vw"
              format="webp"
              quality={88}
            />
            <figcaption class="mono">DECISIONS STAY IN THE RECORD</figcaption>
          </figure>
          <div class="entry-copy">
            <h3>Questions stay inside the task.</h3>
            <p>
              When the agent needs a decision, the question and your answer are
              part of the same record as the work itself — inspectable later,
              never lost in chat scroll.
            </p>
          </div>
        </div>
      </article>
    </section>

    <!-- 02 · STATEMENT -->
    <section class="band band--paper statement" data-theme="paper" data-section="02 THESIS">
      <div class="ticks" aria-hidden="true"><s></s><s></s><s></s><s></s><s></s></div>
      <p class="statement-text" id="statement">
        <span>PROGRESS</span>
        <span>HAS A</span>
        <span>MEMORY</span>
      </p>
    </section>

    <!-- 03 · RUNTIME -->
    <section class="band band--night runtime" id="runtime" data-theme="night" data-section="03 RUNTIME">
      <div class="ticks" aria-hidden="true"><s></s><s></s><s></s><s></s><s></s></div>

      <header class="band-head">
        <p class="band-index mono">02</p>
        <h2 class="band-title" data-scramble>RUNTIME</h2>
        <p class="band-note mono">Append-only execution record</p>
      </header>

      <div class="runtime-lede">
        <h3>Every step becomes a fact.</h3>
        <p>
          Messages, Tool&nbsp;Calls, Tool&nbsp;Results, and termination facts
          enter one Event&nbsp;Log. Context, UI, and recovery are projections
          over the same recorded execution — so interrupted work can resume
          instead of restarting.
        </p>
        <a class="mono runtime-link" href={architectureUrl} target="_blank" rel="noreferrer"
          >READ ARCHITECTURE.MD&nbsp;↗</a
        >
      </div>

      <ol class="ledger" aria-label="Maka execution flow">
        <li>
          <span class="mono">01</span>
          <b>Request</b>
          <p class="mono">A turn begins with your intent.</p>
        </li>
        <li>
          <span class="mono">02</span>
          <b>AgentRun</b>
          <p class="mono">Model reasons, tools act.</p>
        </li>
        <li>
          <span class="mono">03</span>
          <b>Event&nbsp;Log</b>
          <p class="mono">Facts append. Nothing rewrites.</p>
        </li>
        <li>
          <span class="mono">04</span>
          <b>Projection</b>
          <p class="mono">Context and UI derive from the log.</p>
        </li>
        <li>
          <span class="mono">05</span>
          <b>Recovery</b>
          <p class="mono">Work survives interruption.</p>
        </li>
      </ol>
    </section>

    <!-- 04 · SURFACES -->
    <section class="band band--paper surfaces" data-theme="paper" data-section="04 SURFACES">
      <div class="ticks" aria-hidden="true"><s></s><s></s><s></s><s></s><s></s></div>

      <header class="band-head">
        <p class="band-index mono">03</p>
        <h2 class="band-title" data-scramble>SURFACES</h2>
        <p class="band-note mono">One engine · several fronts</p>
      </header>

      <ul class="surface-list">
        <li><b>DESKTOP</b><span class="mono">The full companion workspace.</span></li>
        <li><b>TUI</b><span class="mono">The same tasks in your terminal.</span></li>
        <li><b>CLI</b><span class="mono">Scriptable, single-shot runs.</span></li>
        <li><b>HEADLESS</b><span class="mono">Embedded and automated execution.</span></li>
      </ul>
    </section>

    <!-- 05 · SOURCE / CTA -->
    <section class="band band--paper cta" data-theme="paper" data-section="05 SOURCE">
      <div class="ticks" aria-hidden="true"><s></s><s></s><s></s><s></s><s></s></div>

      <p class="cta-note mono">
        Source-first. No waitlist, no telemetry pitch —<br />
        read the implementation yourself.
      </p>

      <a class="cta-link" href={githubUrl} target="_blank" rel="noreferrer">
        <span class="line"><span>VIEW</span></span>
        <span class="line"><span>SOURCE&nbsp;<b aria-hidden="true">↗</b></span></span>
      </a>

      <div class="cta-foot mono">
        <a href={githubUrl} target="_blank" rel="noreferrer">github.com/maka-agent/maka-agent</a>
        <a href={architectureUrl} target="_blank" rel="noreferrer">ARCHITECTURE.md ↗</a>
        <span>MAKA © 2026</span>
      </div>
    </section>
  </main>

  <footer class="shell shell--bottom" aria-label="Telemetry">
    <p class="mono" aria-label="Local time"><span id="tz">GMT</span>&nbsp;<b id="clock">--:--:--</b></p>
    <p class="mono shell-pointer" aria-hidden="true"><b id="coords">0000&nbsp;X&nbsp;0000&nbsp;Y</b></p>
    <p class="mono shell-progress">
      <span id="section-label">00 INTRO</span>&nbsp;·&nbsp;<b id="scroll-pct">000%</b>
    </p>
  </footer>

  <script>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const clock = document.getElementById("clock");
    const tz = document.getElementById("tz");
    const coords = document.getElementById("coords");
    const scrollPct = document.getElementById("scroll-pct");
    const sectionLabel = document.getElementById("section-label");
    const statement = document.getElementById("statement");
    const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-section]"));

    /* Clock — real local time with real UTC offset. */
    const offsetMinutes = -new Date().getTimezoneOffset();
    const sign = offsetMinutes >= 0 ? "+" : "-";
    const offsetHours = Math.abs(offsetMinutes) / 60;
    if (tz) tz.textContent = `GMT${sign}${Number.isInteger(offsetHours) ? offsetHours : offsetHours.toFixed(1)}`;
    const formatTime = new Intl.DateTimeFormat("en-GB", {
      hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false,
    });
    const tick = () => { if (clock) clock.textContent = formatTime.format(new Date()); };
    tick();
    window.setInterval(tick, 1000);

    /* Pointer telemetry — real cursor coordinates. */
    const pad = (value: number) => String(Math.max(0, Math.round(value))).padStart(4, "0");
    window.addEventListener("pointermove", (event) => {
      if (coords) coords.textContent = `${pad(event.clientX)} X ${pad(event.clientY)} Y`;
    }, { passive: true });

    /* Scroll telemetry + statement fill + section label. */
    let scrollQueued = false;
    const onScroll = () => {
      scrollQueued = false;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const progress = max > 0 ? window.scrollY / max : 0;
      if (scrollPct) scrollPct.textContent = `${String(Math.round(progress * 100)).padStart(3, "0")}%`;

      const middle = window.scrollY + window.innerHeight * 0.5;
      let current = sections[0];
      for (const section of sections) {
        if (section.offsetTop <= middle) current = section;
      }
      const label = current?.dataset.section ?? "00 INTRO";
      if (sectionLabel && sectionLabel.textContent !== label) sectionLabel.textContent = label;

      if (statement && !reduceMotion) {
        const rect = statement.getBoundingClientRect();
        const fill = 1 - Math.min(1, Math.max(0, (rect.top + rect.height * 0.6) / window.innerHeight));
        statement.style.setProperty("--fill", `${Math.min(100, fill * 165)}%`);
      }
    };
    window.addEventListener("scroll", () => {
      if (!scrollQueued) {
        scrollQueued = true;
        requestAnimationFrame(onScroll);
      }
    }, { passive: true });
    if (reduceMotion) statement?.style.setProperty("--fill", "100%");
    onScroll();

    /* In-page navigation. */
    const scrollToTarget = (hash: string) => {
      const target = document.querySelector<HTMLElement>(hash);
      target?.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "start" });
    };
    document.querySelectorAll<HTMLAnchorElement>("[data-nav]").forEach((link) => {
      link.addEventListener("click", (event) => {
        const hash = link.getAttribute("href") ?? "";
        if (!hash.startsWith("#")) return;
        event.preventDefault();
        history.replaceState(null, "", hash === "#top" ? location.pathname : hash);
        scrollToTarget(hash);
      });
    });

    /* Keyboard commands mirrored by the [key] hints in the nav. */
    window.addEventListener("keydown", (event) => {
      if (event.metaKey || event.ctrlKey || event.altKey) return;
      const target = event.target as HTMLElement | null;
      if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA")) return;
      const key = event.key.toLowerCase();
      if (key === "w") scrollToTarget("#work");
      else if (key === "r") scrollToTarget("#runtime");
      else if (key === "g") window.open("https://github.com/maka-agent/maka-agent", "_blank", "noreferrer");
    });

    /* Scramble-in for mono labels (skipped under reduced motion). */
    const GLYPHS = "MAKA/#><+=·0123456789";
    const scramble = (element: HTMLElement) => {
      const original = element.dataset.text ?? element.textContent ?? "";
      element.dataset.text = original;
      let frame = 0;
      const total = Math.max(10, original.length * 2);
      const run = () => {
        frame += 1;
        const reveal = Math.floor((frame / total) * original.length);
        element.textContent = original
          .split("")
          .map((char, index) => {
            if (char.trim() === "" || index < reveal) return char;
            return GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
          })
          .join("");
        if (frame < total) requestAnimationFrame(run);
        else element.textContent = original;
      };
      run();
    };
    if (!reduceMotion) {
      document.querySelectorAll<HTMLElement>(".shell-nav [data-scramble]").forEach((link) => {
        const label = link.childNodes[0];
        link.addEventListener("mouseenter", () => {
          if (label?.nodeType === Node.TEXT_NODE) {
            const holder = document.createElement("span");
            link.replaceChild(holder, label);
            holder.textContent = label.textContent;
            scramble(holder);
          } else if (link.firstElementChild instanceof HTMLElement) {
            scramble(link.firstElementChild);
          }
        }, { once: true });
      });
    }

    /* Reveal-on-intersect. */
    const revealables = document.querySelectorAll<HTMLElement>(".entry, .band-head, .runtime-lede, .ledger li, .surface-list li, .cta-link, .cta-note");
    if (reduceMotion) {
      revealables.forEach((element) => element.classList.add("is-in"));
    } else {
      const observer = new IntersectionObserver((entries) => {
        for (const item of entries) {
          if (item.isIntersecting) {
            (item.target as HTMLElement).classList.add("is-in");
            if (item.target instanceof HTMLElement && item.target.matches(".band-head")) {
              const title = item.target.querySelector<HTMLElement>("[data-scramble]");
              if (title) scramble(title);
            }
            observer.unobserve(item.target);
          }
        }
      }, { threshold: 0.2 });
      revealables.forEach((element) => observer.observe(element));
    }
  </script>
</BaseLayout>
