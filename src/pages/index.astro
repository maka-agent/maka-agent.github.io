---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cursor from "../components/Cursor.astro";
import ExecutionField from "../components/ExecutionField.astro";
import Hero from "../components/Hero.astro";
import Loader from "../components/Loader.astro";
import Rules from "../components/Rules.astro";
import Runtime from "../components/Runtime.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SourceCta from "../components/SourceCta.astro";
import Statement from "../components/Statement.astro";
import Surfaces from "../components/Surfaces.astro";
import Telemetry from "../components/Telemetry.astro";
import WorkIndex from "../components/WorkIndex.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../content/site";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Loader />
  <ExecutionField />
  <Rules />
  <SiteHeader />

  <main id="main-content">
    <Hero />
    <WorkIndex />
    <Statement />
    <Runtime />
    <Surfaces />
    <SourceCta />
  </main>

  <Telemetry />
  <Cursor />

  <script src="../scripts/site.ts"></script>
</BaseLayout>
